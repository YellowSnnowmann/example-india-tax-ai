# Leave empty for same-origin (single Next.js app). Set only if using a separate backend.
NEXT_PUBLIC_BACKEND_URL=

# Base URL of this app (for OAuth callback). Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database & cache
DATABASE_URL=mongodb://localhost:27017/lexai
REDIS_URL=redis://localhost:6379

# OpenAI (chat + embeddings)
OPENAI_API_KEY=your-openai-api-key

# Alphahuman Memory API — required for book/case ingestion and RAG 
ALPHAHUMAN_TOKEN=your-alphahuman-api-token
# Optional: override API base URL
# ALPHAHUMAN_BASE_URL=https://staging-api.alphahuman.xyz

# Path to scraped cases (for npm run cases:ingest)
# SCRAPED_CASES_PATH=/path/to/Poc/data/scraped-cases

# Optional: bypass auth for POST /api/cases/absorb when X-Cases-Absorb-Secret header matches
# CASES_ABSORB_SECRET=local-dev-secret

# eCourts CNR lookup (manual CAPTCHA in Case Search UI)
ECOURTS_BASE_URL=https://services.ecourts.gov.in/ecourtindia_v6/

# Auth (JWT + Google OAuth)
JWT_SECRET=your-secret-minimum-32-chars-for-production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
